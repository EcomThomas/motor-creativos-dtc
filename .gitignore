# --- Secretos: NUNCA commitear (patrón amplio a propósito: ante la duda, se ignora) ---
*.env
.env*
*secret*
*token*
# Excepción: la PLANTILLA sí se versiona (no lleva valores reales)
!.env.example

# --- Descargas de trabajo (videos/imágenes de ads) = data de cliente: quedan LOCALES ---
descargas*/

# --- Perfil de tienda por usuario (multi-tenant): queda LOCAL ---
config.local.json

# --- Config local del harness (no compartir) ---
.claude/settings.local.json

# --- Python ---
__pycache__/
*.pyc

# --- Temporales de Office / OS ---
~$*
.DS_Store
Thumbs.db

# --- Casos reales = DATA DE CLIENTE: quedan LOCALES por defecto (Spine, scripts, ads, briefs) ---
# El método (metodo/, scripts/) sí se versiona; los casos concretos no, salvo decisión explícita.
casos/*/

